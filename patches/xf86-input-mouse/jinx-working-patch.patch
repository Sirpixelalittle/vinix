 esac
 
 
diff -urN --no-dereference xf86-input-mouse-clean/src/vinix_mouse.c xf86-input-mouse-workdir/src/vinix_mouse.c
--- xf86-input-mouse-clean/src/vinix_mouse.c	1969-12-31 18:00:00.000000000 -0600
+++ xf86-input-mouse-workdir/src/vinix_mouse.c
@@ -0,0 +1,159 @@
+#ifdef HAVE_XORG_CONFIG_H
+#include <xorg-config.h>
+#endif
+
+#include <xorg-server.h>
+#include <X11/X.h>
+#include <X11/Xproto.h>
+#include "inputstr.h"
+#include "scrnintstr.h"
+#include "mipointer.h"
+
+#include "xf86.h"
+#include "xf86Xinput.h"
+#include "mouse.h"
+#include "xf86_OSlib.h"
+#include "xisb.h"
+
+#include <stdio.h>
+#include <errno.h>
+#include <stdbool.h>
+#include <stdint.h>
+
+#include <sys/stat.h>
+#include <sys/ioctl.h>
+#include <unistd.h>
+#include <vinix/seat.h>
+
+extern int xf86VinixSeatFd(void);
+
+static Bool (*vinixWrappedDeviceControl)(DeviceIntPtr device, int what);
+
+#define MOUSE_FLAG_LB (1 << 0)
+#define MOUSE_FLAG_RB (1 << 1)
+#define MOUSE_FLAG_MB (1 << 2)
+
+struct mouse_packet {
+    uint8_t flags;
+    int32_t x_mov;
+    int32_t y_mov;
+};
+
+static void vinixReadInput(InputInfoPtr pInfo) {
+    MouseDevPtr mouse = pInfo->private;
+    struct mouse_packet packet;
+
+    if (read(pInfo->fd, &packet, sizeof(struct mouse_packet)) == sizeof(struct mouse_packet)) {
+        int b = mouse->lastButtons;
+        b &= ~0x7;
+
+        /* MousePostEvent accepts the driver's historical natural button
+         * mask (right, middle, left), then translates it to X button order. */
+        b |= (packet.flags & MOUSE_FLAG_LB) ? 4 : 0;
+        b |= (packet.flags & MOUSE_FLAG_MB) ? 2 : 0;
+        b |= (packet.flags & MOUSE_FLAG_RB) ? 1 : 0;
+
+        mouse->PostEvent(pInfo, b, packet.x_mov, -packet.y_mov, 0, 0);
+    }
+}
+
+static int vinixMouseProc(DeviceIntPtr device, int what) {
+    InputInfoPtr pInfo = device->public.devicePrivate;
+    struct vinix_seat_attach_input attachment = {
+        .lease_fd = xf86VinixSeatFd()
+    };
+    int result = vinixWrappedDeviceControl(device, what);
+
+    if (what != DEVICE_ON || result != Success || pInfo->fd == -1)
+        return result;
+
+    /* MouseProc opens the descriptor used by the input thread during
+     * DEVICE_ON. Bind that exact open file description to the seat lease;
+     * descriptors opened during PreInit are only transient probes. */
+    if (ioctl(pInfo->fd, VINIX_SEAT_ATTACH_INPUT, &attachment) < 0) {
+        xf86Msg(X_ERROR, "%s: cannot attach mouse to seat0: %s\n",
+                pInfo->name, strerror(errno));
+        vinixWrappedDeviceControl(device, DEVICE_OFF);
+        return BadValue;
+    }
+
+    return result;
+}
+
+static Bool vinixPreInit(InputInfoPtr pInfo, const char *proto, int flag) {
+    MouseDevPtr mouse;
+
+    mouse = pInfo->private;
+
+    mouse->protocol = proto;
+
+    /* Built-in OS protocols return from the generic driver's protocol path
+     * before it processes the common mouse options.  Do that work here so
+     * axis inversion defaults, button maps, and emulation state are fully
+     * initialised.  In particular, zeroed invX/invY would discard every
+     * relative-motion delta while leaving button events functional. */
+#if GET_ABI_MAJOR(ABI_XINPUT_VERSION) < 12
+    xf86CollectInputOptions(pInfo, NULL, pInfo->options);
+#else
+    COLLECT_INPUT_OPTIONS(pInfo, NULL);
+#endif
+    xf86ProcessCommonOptions(pInfo, pInfo->options);
+    mouse->CommonOptions(pInfo);
+
+    if (pInfo->device_control != vinixMouseProc) {
+        vinixWrappedDeviceControl = pInfo->device_control;
+        pInfo->device_control = vinixMouseProc;
+    }
+    pInfo->read_input = vinixReadInput;
+    return true;
+}
+
+#define DEVPATH "/dev/mouse"
+
+static const char *getdevice(InputInfoPtr pInfo, const char *proto, int flag){
+    struct stat st;
+
+    if (stat(DEVPATH, &st) == -1)
+        return NULL;
+
+    pInfo->options = xf86AddNewOption(pInfo->options, "Device", DEVPATH);
+
+    return DEVPATH;
+}
+
+static int interfacesupport() {
+    return MSE_PS2;
+}
+
+static const char *names[] = {
+    "VinixMouseDev", NULL
+};
+
+static const char **protonames() {
+    return names;
+}
+
+static const char *defaultproto() {
+    return "VinixMouseDev";
+}
+
+static Bool isdefault(const char *protocol) {
+    return strcmp(protocol, defaultproto()) == 0;
+}
+
+OSMouseInfoPtr OSMouseInit(int flag) {
+    OSMouseInfoPtr p;
+
+    p = calloc(sizeof(OSMouseInfoRec), 1);
+
+    if (p == NULL)
+        return NULL;
+
+    p->SupportedInterfaces = interfacesupport;
+    p->BuiltinNames = protonames;
+    p->FindDevice = getdevice;
+    p->DefaultProtocol = defaultproto;
+    p->CheckProtocol = isdefault;
+    p->PreInit = vinixPreInit;
+    return p;
+}
