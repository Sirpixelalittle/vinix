+static int
+vinix_fb_ioctl(int fd, unsigned long request, void *arg)
+{
+    struct vinix_seat_display_info info;
+
+    switch (request) {
+    case FBIOGET_FSCREENINFO: {
+        struct fb_fix_screeninfo *fix = arg;
+        if (ioctl(fd, VINIX_SEAT_GET_DISPLAY_INFO, &info) < 0)
+            return -1;
+        memset(fix, 0, sizeof(*fix));
+        strncpy(fix->id, "Vinix seat", sizeof(fix->id));
+        fix->smem_len = info.buffer_size;
+        fix->type = FB_TYPE_PACKED_PIXELS;
+        fix->visual = FB_VISUAL_TRUECOLOR;
+        fix->line_length = info.pitch;
+        return 0;
+    }
+    case FBIOGET_VSCREENINFO: {
+        struct fb_var_screeninfo *var = arg;
+        if (ioctl(fd, VINIX_SEAT_GET_DISPLAY_INFO, &info) < 0)
+            return -1;
+        memset(var, 0, sizeof(*var));
+        var->xres = var->xres_virtual = info.width;
+        var->yres = var->yres_virtual = info.height;
+        var->bits_per_pixel = info.bits_per_pixel;
+        var->red.length = info.red_size;
+        var->red.offset = info.red_shift;
+        var->green.length = info.green_size;
+        var->green.offset = info.green_shift;
+        var->blue.length = info.blue_size;
+        var->blue.offset = info.blue_shift;
+        var->activate = FB_ACTIVATE_NOW;
+        return 0;
+    }
+    case FBIOPUT_VSCREENINFO: {
+        struct fb_var_screeninfo current;
+        struct fb_var_screeninfo *requested = arg;
+        if (vinix_fb_ioctl(fd, FBIOGET_VSCREENINFO, &current) < 0)
+            return -1;
+        if (requested->xres != current.xres || requested->yres != current.yres
+                || requested->bits_per_pixel != current.bits_per_pixel) {
+            errno = EINVAL;
+            return -1;
+        }
+        *requested = current;
+        return 0;
+    }
+    case FBIOBLANK:
+    case FBIOPUTCMAP:
+    case FBIOGETCMAP:
+        return 0;
+    case FBIOPAN_DISPLAY:
+        errno = EINVAL;
+        return -1;
+    default:
+        return ioctl(fd, request, arg);
+    }
+}
+
+#define ioctl(fd, request, arg) vinix_fb_ioctl((fd), (request), (void *)(arg))
+#endif
