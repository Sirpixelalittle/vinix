+#include <vinix/seat.h>
+
+static int vinixSeatFd = -1;
+
+_X_EXPORT int
+xf86VinixSeatFd(void)
+{
+    return vinixSeatFd;
+}
 
 void
 xf86OpenConsole(void)
 {
+    struct vinix_seat_state state = {0};
+    struct vinix_seat_acquire acquire = {0};
+
+    if (vinixSeatFd >= 0)
+        return;
+
+    vinixSeatFd = open("/dev/seat0", O_RDWR | O_CLOEXEC);
+    if (vinixSeatFd < 0)
+        FatalError("Cannot open /dev/seat0: %s\n", strerror(errno));
+
+    if (ioctl(vinixSeatFd, VINIX_SEAT_GET_STATE, &state) < 0)
+        FatalError("Cannot query /dev/seat0: %s\n", strerror(errno));
+
+    acquire.terminal_id = state.terminal_id;
+    acquire.capabilities = VINIX_SEAT_CAP_ALL;
+    if (ioctl(vinixSeatFd, VINIX_SEAT_ACQUIRE, &acquire) < 0)
+        FatalError("Cannot acquire seat0 for tty%u: %s\n",
+                   acquire.terminal_id, strerror(errno));
 }
 
 void
 xf86CloseConsole(void)
 {
+    if (vinixSeatFd < 0)
+        return;
+    if (ioctl(vinixSeatFd, VINIX_SEAT_RELEASE, NULL) < 0 && errno != EINVAL)
+        xf86Msg(X_WARNING, "Cannot release seat0: %s\n", strerror(errno));
+    close(vinixSeatFd);
+    vinixSeatFd = -1;
 }
 
