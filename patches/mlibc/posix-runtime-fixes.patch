+int sys_ptsname(int fd, char *buffer, size_t length) {
+	unsigned int index;
+	int result;
+	if(int e = sys_ioctl(fd, TIOCGPTN, &index, &result); e)
+		return e;
+
+	static constexpr char prefix[] = "/dev/pts/";
+	char digits[10];
+	size_t digit_count = 0;
+	do {
+		digits[digit_count++] = static_cast<char>('0' + index % 10);
+		index /= 10;
+	} while(index);
+
+	constexpr size_t prefix_length = sizeof(prefix) - 1;
+	if(prefix_length + digit_count + 1 > length)
+		return ERANGE;
+	for(size_t i = 0; i < prefix_length; ++i)
+		buffer[i] = prefix[i];
+	for(size_t i = 0; i < digit_count; ++i)
+		buffer[prefix_length + i] = digits[digit_count - i - 1];
+	buffer[prefix_length + digit_count] = '\0';
+	return 0;
+}
+
+int sys_unlockpt(int fd) {
