-		return
-	}
-	if bmessage != '' {
-		println(bmessage)
-	}
-	if os.user_os() == 'windows' {
-		os.system('dir ${short_v_name}*.exe')
-	} else {
-		os.system('ls -lartd ${short_v_name}*')
-	}
-	println(message)
-}
-
-fn backup_old_version_and_rename_newer(short_v_name string) !bool {
