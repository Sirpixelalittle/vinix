+module net
+
+// Vinix uses mlibc's Linux-compatible socket address ABI.
+const max_unix_path = 108
+
+pub struct C.addrinfo {
+mut:
+	ai_family    int
+	ai_socktype  int
+	ai_flags     int
+	ai_protocol  int
+	ai_addrlen   int
