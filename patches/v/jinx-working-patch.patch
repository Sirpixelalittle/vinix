diff -urN --no-dereference v-clean/vlib/term/termios/termios_vinix.c.v v-workdir/vlib/term/termios/termios_vinix.c.v
--- v-clean/vlib/term/termios/termios_vinix.c.v	1969-12-31 18:00:00.000000000 -0600
+++ v-workdir/vlib/term/termios/termios_vinix.c.v
@@ -0,0 +1,87 @@
+// Copyright (c) 2019-2024 Alexander Medvednikov. All rights reserved.
+// Use of this source code is governed by an MIT license
+// that can be found in the LICENSE file.
+//
+// Vinix uses mlibc's Linux-compatible termios ABI.
+module termios
+
+#include <termios.h>
+#include <sys/ioctl.h>
+
+const cclen = 32
+
+type TcFlag = int
+type Speed = int
+type Cc = u8
+
+// Termios stores the terminal options on Vinix.
+pub struct C.termios {
+mut:
+	c_iflag  TcFlag
+	c_oflag  TcFlag
+	c_cflag  TcFlag
+	c_lflag  TcFlag
+	c_line   Cc
+	c_cc     [cclen]Cc
+	c_ispeed Speed
+	c_ospeed Speed
+}
+
+fn C.tcgetattr(fd int, termios_p &C.termios) int
+
+fn C.tcsetattr(fd int, optional_actions int, const_termios_p &C.termios) int
+
+fn C.ioctl(fd int, request u64, args ...voidptr) int
+
+// flag provides a termios flag of the correct size.
+@[inline]
+pub fn flag(value int) TcFlag {
+	return TcFlag(value)
+}
+
+@[inline]
+pub fn invert(value TcFlag) TcFlag {
+	return ~int(value)
+}
+
+pub struct Termios {
+pub mut:
+	c_iflag  TcFlag
+	c_oflag  TcFlag
+	c_cflag  TcFlag
+	c_lflag  TcFlag
+	c_line   Cc
+	c_cc     [cclen]Cc
+	c_ispeed Speed
+	c_ospeed Speed
+}
+
+@[inline]
+pub fn tcgetattr(fd int, mut termios_p Termios) int {
+	unsafe {
+		return C.tcgetattr(fd, &C.termios(termios_p))
+	}
+}
+
+@[inline]
+pub fn tcsetattr(fd int, optional_actions int, mut termios_p Termios) int {
+	unsafe {
+		return C.tcsetattr(fd, optional_actions, &C.termios(termios_p))
+	}
+}
+
+@[inline]
+pub fn ioctl(fd int, request u64, arg voidptr) int {
+	unsafe {
+		return C.ioctl(fd, request, arg)
+	}
+}
+
+pub fn set_state(fd int, new_state Termios) int {
+	mut x := new_state
+	return tcsetattr(fd, C.TCSANOW, mut x)
+}
+
+pub fn (mut t Termios) disable_echo() {
+	t.c_lflag &= invert(C.ECHO)
+}
