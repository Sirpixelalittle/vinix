-				vversion += ', timestamp: ' + latest_v_commit_time.output.trim_space()
-			}
-		}
-		println('Current V version: ${vversion}')
-	}
-}
-
-fn (app App) backup(file string) {
-	backup_file := '${file}_old.exe'
-	println('> backing up `${file}` to `${backup_file}` ...')
